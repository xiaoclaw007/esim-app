# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-string
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite:///./esim.db

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JoyTel Warehouse
JOYTEL_WAREHOUSE_URL=https://warehouse.joytelecom.com
JOYTEL_CUSTOMER_CODE=your_customer_code
JOYTEL_CUSTOMER_AUTH=your_customer_auth

# JoyTel RSP+
JOYTEL_RSP_URL=https://esim.joytelecom.com/openapi
JOYTEL_APP_ID=your_app_id
JOYTEL_APP_SECRET=your_app_secret

# AWS SES
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@example.com
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
